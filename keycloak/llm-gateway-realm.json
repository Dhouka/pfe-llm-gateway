{
  "realm": "llm-gateway",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "accessTokenLifespan": 3600,
  "roles": {
    "realm": [
      {
        "name": "llm-user",
        "description": "Allowed to call POST /llm/chat on the gateway"
      },
      {
        "name": "audit-viewer",
        "description": "Allowed to read GET /audit on the gateway"
      }
    ]
  },
  "clients": [
    {
      "clientId": "gateway-client",
      "name": "LLM Secure Gateway",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["http://localhost:8080/*", "http://localhost:5000/*"],
      "webOrigins": ["*"]
    }
  ],
  "users": [
    {
      "username": "dev-user",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "dev-user",
          "temporary": false
        }
      ],
      "realmRoles": ["llm-user", "audit-viewer"]
    }
  ]
}
