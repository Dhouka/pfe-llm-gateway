# Copy to .env and fill in real values before running `docker compose up -d`.
# .env itself is gitignored — never commit real credentials.

# Keycloak admin console login (local dev instance on :8180)
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change-me

# Gateway: override if Keycloak isn't on localhost:8180 / realm isn't "llm-gateway"
KEYCLOAK_ISSUER_URI=http://localhost:8180/realms/llm-gateway

# Gateway: override if pii-service isn't on localhost:5001
PII_SERVICE_URL=http://localhost:5001
